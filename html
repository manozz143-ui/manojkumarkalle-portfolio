<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #0a1214;
    --bg-2: #0e1a1d;
    --surface: #101c1f;
    --surface-2: #142226;
    --line: #1e2f33;
    --teal: #2fd6c4;
    --teal-dim: #1c8f83;
    --amber: #e79a5c;
    --text: #e9efee;
    --text-muted: #7f9497;
    --text-faint: #4d5f62;
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  *{ margin:0; padding:0; box-sizing:border-box; }

  html{ scroll-behavior:smooth; }

  body{
    background:
      radial-gradient(1100px 600px at 85% -10%, rgba(47,214,196,0.08), transparent 60%),
      radial-gradient(900px 500px at -10% 20%, rgba(231,154,92,0.05), transparent 55%),
      var(--bg);
    color:var(--text);
    font-family:var(--font-body);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }

  a{ color:inherit; text-decoration:none; }

  ::selection{ background:var(--teal); color:#0a1214; }

  .wrap{ max-width:1080px; margin:0 auto; padding:0 28px; }

  /* focus visibility */
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--teal);
    outline-offset:3px;
    border-radius:2px;
  }

  @media (prefers-reduced-motion: reduce){
    *{ animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important; scroll-behavior:auto !important; }
  }

  /* ---------- topbar ---------- */
  .topbar{
    position:sticky; top:0; z-index:50;
    background:rgba(10,18,20,0.82);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  .topbar-inner{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 28px;
    max-width:1080px; margin:0 auto;
  }
  .brand{
    font-family:var(--font-mono); font-size:14px; letter-spacing:0.02em;
    color:var(--text);
  }
  .brand .dot{ color:var(--teal); }
  .nav{ display:flex; gap:28px; }
  .nav a{
    font-family:var(--font-mono); font-size:12px; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--text-muted);
    transition:color .2s ease;
  }
  .nav a:hover{ color:var(--teal); }
  @media (max-width:640px){ .nav{ gap:16px; } .nav a{ font-size:11px; } }

  /* ---------- hero ---------- */
  .hero{
    padding:96px 0 80px;
    border-bottom:1px solid var(--line);
    position:relative;
    overflow:hidden;
  }
  .status-line{
    font-family:var(--font-mono); font-size:12px; color:var(--teal);
    letter-spacing:0.08em; margin-bottom:28px;
    display:flex; align-items:center; gap:10px;
  }
  .status-line .pulse{
    width:7px; height:7px; border-radius:50%; background:var(--teal);
    box-shadow:0 0 0 0 rgba(47,214,196,0.6);
    animation:pulse 2.2s infinite;
  }
  @keyframes pulse{
    0%{ box-shadow:0 0 0 0 rgba(47,214,196,0.5); }
    70%{ box-shadow:0 0 0 8px rgba(47,214,196,0); }
    100%{ box-shadow:0 0 0 0 rgba(47,214,196,0); }
  }
  h1.headline{
    font-family:var(--font-display); font-weight:700;
    font-size:clamp(2.4rem, 6vw, 4.4rem);
    line-height:1.05; letter-spacing:-0.02em;
    max-width:760px;
  }
  h1.headline .accent{ color:var(--teal); }
  .subhead{
    margin-top:24px; max-width:560px;
    font-size:17px; color:var(--text-muted);
  }
  .hero-meta{
    margin-top:44px; display:flex; gap:36px; flex-wrap:wrap;
    font-family:var(--font-mono); font-size:12px; color:var(--text-faint);
  }
  .hero-meta div span{ display:block; color:var(--text-muted); font-size:11px; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.08em; }
  .hero-meta div strong{ color:var(--text); font-weight:400; font-size:13px; }

  .cta-row{ margin-top:40px; display:flex; gap:14px; flex-wrap:wrap; }
  .btn{
    font-family:var(--font-mono); font-size:12px; letter-spacing:0.05em;
    padding:12px 22px; border-radius:3px; border:1px solid var(--line);
    transition:all .2s ease;
  }
  .btn.primary{ background:var(--teal); color:#08181a; border-color:var(--teal); font-weight:500; }
  .btn.primary:hover{ background:#3fe6d3; }
  .btn.ghost{ color:var(--text-muted); }
  .btn.ghost:hover{ color:var(--text); border-color:var(--text-muted); }

  /* orbit line signature */
  .orbit-line{ position:absolute; right:-60px; top:40px; width:420px; height:420px; opacity:0.5; pointer-events:none; }
  @media (max-width:900px){ .orbit-line{ display:none; } }

  /* ---------- section shared ---------- */
  section{ padding:88px 0; border-bottom:1px solid var(--line); }
  .eyebrow{
    font-family:var(--font-mono); font-size:12px; color:var(--amber);
    letter-spacing:0.1em; text-transform:uppercase; margin-bottom:14px;
  }
  h2.section-title{
    font-family:var(--font-display); font-weight:600;
    font-size:clamp(1.6rem, 3.4vw, 2.2rem);
    margin-bottom:16px; letter-spacing:-0.01em;
  }
  .section-desc{ color:var(--text-muted); max-width:600px; font-size:15.5px; margin-bottom:52px; }

  /* ---------- systems / skills ---------- */
  .systems-grid{
    display:grid; grid-template-columns:repeat(3, 1fr); gap:1px;
    background:var(--line); border:1px solid var(--line);
  }
  @media (max-width:760px){ .systems-grid{ grid-template-columns:repeat(2,1fr); } }
  @media (max-width:480px){ .systems-grid{ grid-template-columns:1fr; } }
  .system-cell{
    background:var(--surface); padding:26px 22px; transition:background .2s ease;
  }
  .system-cell:hover{ background:var(--surface-2); }
  .system-cell .tag{
    font-family:var(--font-mono); font-size:11px; color:var(--teal-dim);
    letter-spacing:0.06em; text-transform:uppercase; margin-bottom:10px; display:block;
  }
  .system-cell h3{
    font-family:var(--font-display); font-size:16px; font-weight:600; margin-bottom:8px;
  }
  .system-cell p{ color:var(--text-muted); font-size:13.5px; }

  /* ---------- trajectory (space pivot) ---------- */
  .trajectory{
    display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:start;
  }
  @media (max-width:800px){ .trajectory{ grid-template-columns:1fr; } }
  .trajectory p{ color:var(--text-muted); font-size:15px; margin-bottom:16px; }
  .trajectory strong{ color:var(--text); font-weight:500; }
  .target-list{ font-family:var(--font-mono); font-size:13px; }
  .target-list li{ list-style:none; padding:14px 0; border-top:1px solid var(--line); display:flex; justify-content:space-between; color:var(--text-muted); }
  .target-list li:last-child{ border-bottom:1px solid var(--line); }
  .target-list li span.name{ color:var(--text); }
  .target-list li span.tag2{ color:var(--amber); font-size:11px; }

  /* ---------- field log (travel/photography) ---------- */
  .log-list{ display:flex; flex-direction:column; }
  .log-entry{
    display:grid; grid-template-columns:140px 1fr; gap:28px;
    padding:26px 0; border-top:1px solid var(--line);
  }
  .log-entry:last-child{ border-bottom:1px solid var(--line); }
  @media (max-width:600px){ .log-entry{ grid-template-columns:1fr; gap:8px; } }
  .log-coord{ font-family:var(--font-mono); font-size:12px; color:var(--teal); line-height:1.7; }
  .log-coord .route{ color:var(--text-faint); display:block; font-size:11px; margin-top:2px; }
  .log-body h3{ font-family:var(--font-display); font-size:16.5px; font-weight:600; margin-bottom:6px; }
  .log-body p{ color:var(--text-muted); font-size:14px; }

  /* ---------- contact ---------- */
  .contact{ border-bottom:none; text-align:left; }
  .contact-inner{
    display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:32px;
  }
  .contact h2{
    font-family:var(--font-display); font-weight:700;
    font-size:clamp(1.8rem, 4vw, 2.6rem); max-width:520px; letter-spacing:-0.01em;
  }
  .contact-links{ display:flex; flex-direction:column; gap:10px; }
  .contact-links a{
    font-family:var(--font-mono); font-size:14px; color:var(--text-muted);
    display:flex; align-items:center; gap:10px;
  }
  .contact-links a:hover{ color:var(--teal); }
  .contact-links a::before{ content:'→'; color:var(--teal); }

  footer{
    padding:28px 0 40px;
    font-family:var(--font-mono); font-size:11px; color:var(--text-faint);
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;
  }
</style>
</head>
